# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/transitops

# Security / JWT Configuration
JWT_SECRET=your_super_secret_jwt_access_token_key_here_at_least_32_characters
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_key_here_at_least_32_characters
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Email Service (Nodemailer Configuration)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@transitops.com
