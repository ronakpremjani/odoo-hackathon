{
  "openapi": "3.0.0",
  "info": {
    "title": "TransitOps API Engine",
    "version": "1.0.0",
    "description": "Enterprise Transport Operations ERP - Backend Services API"
  },
  "servers": [
    {
      "url": "http://localhost:8000/api/v1",
      "description": "Development server"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Authenticate User",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Successfully authenticated" }
        }
      }
    },
    "/dashboard/kpis": {
      "get": {
        "summary": "Retrieve High-Level Fleet KPIs",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Returns operational KPIs and ROI" }
        }
      }
    },
    "/vehicles": {
      "get": {
        "summary": "List Vehicles",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "A list of fleet vehicles" }
        }
      },
      "post": {
        "summary": "Register a Vehicle",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "plateNumber": { "type": "string" },
                  "make": { "type": "string" },
                  "model": { "type": "string" },
                  "year": { "type": "number" },
                  "type": { "type": "string" },
                  "mileage": { "type": "number" },
                  "fuelType": { "type": "string" }
                },
                "required": ["plateNumber", "make", "model", "year", "type"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Vehicle registered" }
        }
      }
    },
    "/vehicles/{id}/metrics": {
      "get": {
        "summary": "Retrieve operational and ROI metrics for a single vehicle",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Returns vehicle-specific efficiency, mileage, and ROI metrics" }
        }
      }
    },
    "/drivers": {
      "get": {
        "summary": "List Drivers",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "A list of drivers" }
        }
      },
      "post": {
        "summary": "Register a Driver",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "201": { "description": "Driver registered" }
        }
      }
    },
    "/trips": {
      "get": {
        "summary": "List Trips",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Dispatched trips list" }
        }
      },
      "post": {
        "summary": "Dispatch a Trip",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "210": { "description": "Trip dispatched successfully" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
